# Git LFS configuration for precompiled Slang binaries

# Windows precompiled libraries and executables
*.lib filter=lfs diff=lfs merge=lfs -text
*.dll filter=lfs diff=lfs merge=lfs -text
*.exe filter=lfs diff=lfs merge=lfs -text

# Linux precompiled libraries
*.so filter=lfs diff=lfs merge=lfs -text
*.so.* filter=lfs diff=lfs merge=lfs -text

# Keep source files in git (not LFS) and force text diffs
*.cpp   -filter text diff
*.hpp   -filter text diff
*.h     -filter text diff
*.slang -filter text diff
*.md    -filter text diff

#Images
*.jpg filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text
*.exr filter=lfs diff=lfs merge=lfs -text